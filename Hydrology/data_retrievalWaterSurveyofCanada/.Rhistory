#  Inspect the output of print(nc) to confirm the actual variable name for discharge.
#  It might be 'dis24' or similar. Adjust if needed.
discharge_var_name <- "dis24" # Or whatever the correct variable name is
if (discharge_var_name %in% names(nc$var)) {
discharge_data <- ncvar_get(nc, discharge_var_name)
lat <- ncvar_get(nc, "latitude")
lon <- ncvar_get(nc, "longitude")
time <- ncvar_get(nc, "time") # Time in hours since 1900-01-01 00:00:00
time_units <- ncatt_get(nc, "time", "units")$value
time_origin <- sub("hours since ", "", time_units)
time_dates <- as.POSIXct(time * 3600, origin = time_origin, tz = "UTC") # Convert time to dates
cat("\nFirst few time steps:\n")
print(head(time_dates))
cat("\nDimensions of discharge data (time, latitude, longitude):", dim(discharge_data), "\n")
# You can now process the discharge_data, lat, lon, and time_dates
# For example, you could calculate temporal averages, extract time series for specific locations, etc.
} else {
cat(paste("Error: Variable", discharge_var_name, "not found in the NetCDF file.\n"))
cat("Please check the NetCDF file structure.\n")
}
nc_close(nc)
} else {
cat(paste("File", first_version_file, "not found. Please check if download was successful.\n"))
}
## GLOFAS Download
if(!require(ecmwfr)){install.packages("ecmwfr")}
if(!require(RCurl)){install.packages("RCurl")}
if(!require(ncdf4)){install.packages("ncdf4")}
if(!require(sf)){install.packages("sf")}
if(!require(dplyr)){install.packages("dplyr")}
library(ecmwfr)
library(RCurl)
library(ncdf4)
library(sf) # for spatial operations (defining region, optional for this simple case)
library(dplyr) # for data manipulation (optional)
# --- 1. Define Parameters ---
versions <- c("2", "3", "4") # Versions of GloFAS to download
variable_name <- "river_discharge" # Variable to download
dataset_name <- "glofas-reanalysis" # Dataset name in CDS
# Set up UID, API key, and define the parameters
uid <- "b4ed00df-5bd9-494d-b09c-88d51b2762e6"
api_key <- "f0b6de88-c627-4f98-98b4-22453fb77cac"
wf_set_key(user = uid, key = api_key)
# Define the rectangular region covering Iran (example coordinates)
lon_min <- 44
lon_max <- 64
lat_min <- 24
lat_max <- 40
bbox_iran <- c(
lon_min = lon_min,
lat_min = lat_min,
lon_max = lon_max,
lat_max = lat_max
)
# Calculate date range for the last 20 years (approximately)
start_date <- as.Date("2005-01-01")
end_date <- as.Date("2024-12-31")
start_year <- as.integer(format(start_date , "%Y"))
end_year <- as.integer(format(end_date , "%Y"))
years <- as.character(start_year:end_year)
months <- sprintf("%02d", 1:12) # Months 01 to 12
days <- sprintf("%02d", 1:31)
# Set up the CDS API URL with authentication and versions
# cds_api_url <- paste0("https://cds.climate.copernicus.eu/api/v2/resources/glofas",
#                       "?bbox=", lon_min, ",", lat_min, ",", lon_max, ",", lat_max,
#                       "&start_date=", start_date,
#                       "&end_date=", end_date,
#                       "&uid=", uid,
#                       "&api_key=", api_key,
#                       "&version=2,3,4")
# request <- list(
#   dataset_short_name = "cems-glofas-historical",
#   product_type = "reanalysis",
#   variable = "river_discharge_in_the_last_24_hours",
#   version = versions,
#   area = c(lat_max, lon_min, lat_min, lon_max),
#   date = paste(start_date, "/", end_date, sep = ""),
#   format = "netcdf"
# )
for (version in versions) {
output_filename <- paste0("glofas_discharge_v", version, "_iran_", start_year, "-", end_year, ".nc")
cat(paste("Downloading GloFAS v", version, "for Iran...", "\n"))
cat(paste("Saving to:", output_filename, "\n"))
tryCatch({ # Use tryCatch to handle potential download errors
request <- list(
dataset_short_name = dataset_name,
product_type   = "reanalysis", # For historical data
version        = version,
variable       = variable_name,
year           = years,
month          = months,
day            = days,
area           = paste0(bbox_iran["lat_max"], "/", bbox_iran["lon_min"], "/", bbox_iran["lat_min"], "/", bbox_iran["lon_max"]), # N/W/S/E
format         = "netcdf",
target         = output_filename
)
# Perform the CDS API request using ecmwfr package
wf_request(request = request,
user = uid, # Or use your UID directly if not using env vars
key = api_key,  # Or use your API key directly if not using env vars
transfer = TRUE) # Set to TRUE to actually download
cat(paste("GloFAS v", version, "data downloaded successfully.\n"))
}, error = function(e) {
cat(paste("Error downloading GloFAS v", version, "data:\n"))
cat(paste(e$message, "\n"))
cat("Skipping to the next version.\n")
})
}
cat("Download process completed.\n")
