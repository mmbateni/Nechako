library(terra)
library(ecmwfr)
library(sf)
library(dplyr)
# 1) Watershed GROUPS (mask builder) — use plain '&' and request EPSG:3005
wfs_groups <- paste0(
"https://openmaps.gov.bc.ca/geo/pub/WHSE_BASEMAPPING.FWA_WATERSHED_GROUPS_POLY/ows?",
"service=WFS&version=2.0.0&request=GetFeature&",
"typeNames=pub:WHSE_BASEMAPPING.FWA_WATERSHED_GROUPS_POLY&",
"srsName=EPSG:3005&outputFormat=application/json"
)
fwa_groups <- st_read(wfs_groups, quiet = TRUE)
stopifnot(!is.na(st_crs(fwa_groups)))  # should be 3005
# Select watershed groups that define your study area
target_names <- c(
"Nechako River",
"Upper Nechako Reservoir", "Lower Nechako Reservoir",
"Stuart River", "Endako River", "Stellako River", "Chilako River",
"Nautley River", "Cheslatta River"
)
nechako_groups <- fwa_groups %>%
filter(WATERSHED_GROUP_NAME %in% target_names) %>%
st_make_valid()
# If you get 0 rows here, print unique names to adjust:
# sort(unique(fwa_groups$WATERSHED_GROUP_NAME))
# Dissolve the groups into one mask geometry
nechako_mask <- nechako_groups %>% summarise() %>% st_make_valid()
# 2) Assessment WATERSHEDS (20k) — again, plain '&'
wfs_20k <- paste0(
"https://openmaps.gov.bc.ca/geo/pub/WHSE_BASEMAPPING.FWA_WATERSHEDS_POLY/ows?",
"service=WFS&version=2.0.0&request=GetFeature&",
"typeNames=pub:WHSE_BASEMAPPING.FWA_WATERSHEDS_POLY&",
"srsName=EPSG:3005&outputFormat=application/json"
)
fwa_20k <- st_read(wfs_20k, quiet = TRUE)
stopifnot(!is.na(st_crs(fwa_20k)))     # 3005
# Optional: restrict the WFS read to the mask bbox to reduce download size
bb <- st_bbox(nechako_mask)
wfs_20k_bbox <- paste0(
"https://openmaps.gov.bc.ca/geo/pub/WHSE_BASEMAPPING.FWA_WATERSHEDS_POLY/ows?",
"service=WFS&version=2.0.0&request=GetFeature&",
"typeNames=pub:WHSE_BASEMAPPING.FWA_WATERSHEDS_POLY&",
"srsName=EPSG:3005&outputFormat=application/json&",
"bbox=", bb["xmin"], ",", bb["ymin"], ",", bb["xmax"], ",", bb["ymax"]
)
# You can choose either full read or bbox-constrained:
# fwa_20k <- st_read(wfs_20k_bbox, quiet = TRUE)
# 3) Spatially select 20k polygons intersecting the Nechako mask
nechako_20k <- fwa_20k %>%
st_make_valid() %>%
st_filter(nechako_mask)
cat("20k polygons selected:", nrow(nechako_20k), "\n")  # expect hundreds to thousands, not 28
# 4) Dissolve to one basin outline; then transform to WGS84
nechako_basin <- nechako_20k %>% summarise() %>% st_make_valid()
nechako_basin_ll <- st_transform(nechako_basin, 4326)
plot(st_geometry(nechako_basin_ll), col = "lightblue", border = "black", lwd = 1.5)
title("Nechako Basin (FWA 20k → dissolved, WGS84)")
